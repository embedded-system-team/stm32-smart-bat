{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Firmware",
            "type": "shell",
            "command": "make",
            "args": [
                "-C",
                "firmware",
                "-j"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Clean Firmware",
            "type": "shell",
            "command": "make",
            "args": [
                "-C",
                "firmware",
                "clean"
            ]
        }
    ]
}